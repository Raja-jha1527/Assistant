def yolo(text):
  model = YOLO("yolov8n.pt")
  cap = cv2.VideoCapture(2)

  while True:
    ret, frame = cap.read()

    if not ret:
        break

    # Detection
    results = model(frame)

    # Boxes aur labels draw karo
    annotated_frame = results[0].plot()

    cv2.imshow("YOLO Detection", annotated_frame)

    # Q dabakar exit
    if cv2.waitKey(1) & 0xFF == ord("q"):
        break

  cap.release()
  cv2.destroyAllWindows()
